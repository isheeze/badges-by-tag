# Shopify CLI supplies these during `shopify app dev`.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://badges-by-tag.onrender.com
SCOPES=read_themes

# Optional custom shop domain support.
SHOP_CUSTOM_DOMAIN=

# Public app listing/support links.
SUPPORT_EMAIL=badgesbytag@gmail.com
PRIVACY_POLICY_URL=https://badges-by-tag.netlify.app/privacy
TERMS_URL=https://badges-by-tag.netlify.app/terms
SHOPIFY_APP_LISTING_URL=

# Billing is disabled in local/private dev because Shopify Billing API requires public distribution.
# Enable only for a public app deployment with a configured plan.
BILLING_ENABLED=0
FREE_BADGE_LIMIT=3

# Node/React Router runtime.
NODE_ENV=production

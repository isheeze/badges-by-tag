{% comment %}
  Product Badges block
  Renders badge pills for the current product when its tags match mappings saved by the app.
{% endcomment %}

{{ 'product-badges.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-badges.js' | asset_url }}" defer></script>

{%- liquid
  assign mappings = shop.metafields.badges_by_tag.mappings.value
  assign current_product = product
  if current_product == blank and block.settings.product != blank
    assign current_product = block.settings.product
  endif
  assign max_badges = block.settings.max_badges | default: 3
  assign position = block.settings.position | default: 'inline'
  assign layout = block.settings.layout | default: 'wrap'
  assign alignment = block.settings.alignment | default: 'left'
  assign overlay_offset = block.settings.overlay_offset | default: 8
  assign font_size = block.settings.font_size | default: 12
  assign hide_on_mobile = block.settings.hide_on_mobile | default: false
  assign show_first_only = block.settings.show_first_only | default: false
  assign display_limit = max_badges
  if show_first_only
    assign display_limit = 1
  endif
  assign product_tags = current_product.tags | join: ',' | downcase | split: ','
-%}

{%- if current_product == blank -%}
  {%- if request.design_mode -%}
    <div class="bbt-empty" {{ block.shopify_attributes }}>
      Badges by Tag needs a product context. Add this block inside a product section or product card.
    </div>
  {%- endif -%}
{%- elsif mappings == blank -%}
  {%- if request.design_mode -%}
    <div class="bbt-empty" {{ block.shopify_attributes }}>
      No badge mappings saved yet. Open the app, create mappings, then save them.
    </div>
  {%- endif -%}
{%- else -%}
  {%- assign rendered_count = 0 -%}
  <div
    class="bbt-badges"
    data-position="{{ position }}"
    data-layout="{{ layout }}"
    data-alignment="{{ alignment }}"
    data-overlay-offset="{{ overlay_offset }}"
    data-font-size="{{ font_size }}"
    data-hide-mobile="{{ hide_on_mobile }}"
    style="
      --bbt-font-size: {{ font_size }}px;
      --bbt-overlay-offset: {{ overlay_offset }}px;
      display: flex;
      {%- if layout == 'row' -%}
        flex-wrap: nowrap;
        overflow: hidden;
      {%- elsif layout == 'column' -%}
        flex-direction: column;
        flex-wrap: wrap;
      {%- else -%}
        flex-wrap: wrap;
      {%- endif -%}
      gap: {%- if layout == 'compact' -%} 4px {%- else -%} 6px {%- endif -%};
      align-items: {%- if layout == 'column' and alignment == 'center' -%} center {%- elsif layout == 'column' and alignment == 'right' -%} flex-end {%- else -%} center {%- endif -%};
      justify-content: {%- if alignment == 'center' -%} center {%- elsif alignment == 'right' or position == 'top-right' -%} flex-end {%- else -%} flex-start {%- endif -%};
      pointer-events: none;
      z-index: 20;
      {%- if position == 'top-left' -%}
        position: absolute;
        top: {{ overlay_offset }}px;
        left: {{ overlay_offset }}px;
      {%- elsif position == 'top-right' -%}
        position: absolute;
        top: {{ overlay_offset }}px;
        right: {{ overlay_offset }}px;
      {%- endif -%}
    "
    {{ block.shopify_attributes }}
  >
    {%- for mapping in mappings -%}
      {%- if rendered_count >= display_limit -%}
        {%- break -%}
      {%- endif -%}

      {%- liquid
        assign mapping_tag = mapping.tag | strip | downcase
        assign mapping_label = mapping.label | strip
        assign template_type = mapping.templateType | default: 'text'
        assign background_color = mapping.bgColor | default: '#16a34a'
        assign text_color = mapping.textColor | default: '#ffffff'
        assign badge_shape = mapping.shape | default: 'pill'
        assign badge_size = mapping.size | default: 'medium'
        assign badge_text_case = mapping.textCase | default: 'uppercase'
        assign badge_border = mapping.border | default: 'none'
        assign badge_shadow = mapping.shadow | default: 'soft'
        assign font_family = mapping.fontFamily | default: 'system'
        assign font_weight = mapping.fontWeight | default: 'bold'
        assign image_url = mapping.imageUrl | default: ''
        assign image_fit = mapping.imageFit | default: 'cover'
        assign image_url_downcase = image_url | downcase
        assign has_transparent_image = false
        if image_url_downcase contains 'data:image/png' or image_url_downcase contains '.png'
          assign has_transparent_image = true
        endif
        assign badge_width = mapping.badgeWidth | default: 120
        assign badge_height = mapping.badgeHeight | default: 36
        assign text_x = mapping.textX | default: 50
        assign text_y = mapping.textY | default: 50
        assign text_align = mapping.textAlign | default: 'center'
        assign text_shadow = mapping.textShadow | default: 'soft'
        assign rotation = mapping.rotation | default: 0
        assign opacity = mapping.opacity | default: 100
        assign badge_radius = '999px'
        if badge_shape == 'rounded'
          assign badge_radius = '8px'
        elsif badge_shape == 'square'
          assign badge_radius = '2px'
        endif
        assign badge_padding = '3px 10px'
        assign badge_min_height = 24
        if badge_size == 'small'
          assign badge_padding = '2px 8px'
          assign badge_min_height = 20
        elsif badge_size == 'large'
          assign badge_padding = '5px 12px'
          assign badge_min_height = 30
        endif
        if template_type != 'text' or image_url != blank
          assign badge_padding = '0'
        endif
        assign badge_text_transform = 'uppercase'
        if badge_text_case == 'title'
          assign badge_text_transform = 'capitalize'
        elsif badge_text_case == 'none'
          assign badge_text_transform = 'none'
        endif
        assign badge_border_value = '0 solid transparent'
        if badge_border == 'light'
          assign badge_border_value = '1px solid rgba(255, 255, 255, 0.65)'
        elsif badge_border == 'dark'
          assign badge_border_value = '1px solid rgba(0, 0, 0, 0.28)'
        endif
        assign badge_shadow_value = '0 1px 3px rgba(0, 0, 0, 0.16)'
        if badge_shadow == 'none'
          assign badge_shadow_value = 'none'
        elsif badge_shadow == 'bold'
          assign badge_shadow_value = '0 4px 10px rgba(0, 0, 0, 0.22)'
        endif
        assign badge_font_family_value = 'inherit'
        if font_family == 'serif'
          assign badge_font_family_value = 'Georgia, "Times New Roman", serif'
        elsif font_family == 'mono'
          assign badge_font_family_value = '"SFMono-Regular", Consolas, monospace'
        elsif font_family == 'display'
          assign badge_font_family_value = '"Arial Black", Impact, sans-serif'
        endif
        assign badge_font_weight_value = 750
        if font_weight == 'regular'
          assign badge_font_weight_value = 500
        elsif font_weight == 'heavy'
          assign badge_font_weight_value = 900
        endif
        assign badge_background_size = 'cover'
        assign badge_background_repeat = 'repeat'
        if image_fit == 'contain'
          assign badge_background_size = 'contain'
          assign badge_background_repeat = 'no-repeat'
        elsif image_fit == 'stretch'
          assign badge_background_size = '100% 100%'
        endif
        assign badge_clip_path = ''
        if template_type == 'ribbon'
          assign badge_clip_path = 'polygon(0 0, 92% 0, 100% 50%, 92% 100%, 0 100%, 6% 50%)'
        elsif template_type == 'corner'
          assign badge_clip_path = 'polygon(0 0, 100% 0, 86% 100%, 0 100%)'
        elsif template_type == 'burst'
          assign badge_clip_path = 'polygon(50% 0%, 59% 14%, 75% 7%, 78% 24%, 95% 25%, 86% 41%, 100% 50%, 86% 59%, 95% 75%, 78% 76%, 75% 93%, 59% 86%, 50% 100%, 41% 86%, 25% 93%, 22% 76%, 5% 75%, 14% 59%, 0% 50%, 14% 41%, 5% 25%, 22% 24%, 25% 7%, 41% 14%)'
        endif
        assign badge_text_shadow_value = '0 1px 2px rgba(0, 0, 0, 0.24)'
        if text_shadow == 'none'
          assign badge_text_shadow_value = 'none'
        elsif text_shadow == 'bold'
          assign badge_text_shadow_value = '0 2px 6px rgba(0, 0, 0, 0.38)'
        endif
        assign tag_matched = false
      -%}

      {%- if mapping_tag != blank and mapping_label != blank -%}
        {%- for product_tag in product_tags -%}
          {%- assign normalized_product_tag = product_tag | strip -%}
          {%- if normalized_product_tag == mapping_tag -%}
            {%- assign tag_matched = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if tag_matched -%}
        <span
          class="bbt-badge"
          data-template="{{ template_type }}"
          data-shape="{{ badge_shape }}"
          data-size="{{ badge_size }}"
          data-text-case="{{ badge_text_case }}"
          data-border="{{ badge_border }}"
          data-shadow="{{ badge_shadow }}"
          data-font-family="{{ font_family }}"
          data-font-weight="{{ font_weight }}"
          data-image-fit="{{ image_fit }}"
          data-has-image="{% if image_url != blank %}true{% else %}false{% endif %}"
          data-text-align="{{ text_align }}"
          data-text-shadow="{{ text_shadow }}"
          style="
            --bbt-badge-bg: {%- if has_transparent_image -%} transparent {%- else -%} {{ background_color }} {%- endif -%};
            --bbt-badge-color: {{ text_color }};
            --bbt-badge-width: {{ badge_width }}px;
            --bbt-badge-height: {{ badge_height }}px;
            --bbt-text-x: {{ text_x }}%;
            --bbt-text-y: {{ text_y }}%;
            --bbt-rotation: {{ rotation }}deg;
            --bbt-opacity: {{ opacity | divided_by: 100.0 }};
            {%- if image_url != blank -%}
              --bbt-badge-image: url('{{ image_url | escape }}');
            {%- endif -%}
            display: inline-flex;
            align-items: center;
            justify-content: center;
            position: relative;
            box-sizing: border-box;
            width: var(--bbt-badge-width, auto);
            min-width: var(--bbt-badge-width, 0);
            max-width: 100%;
            height: var(--bbt-badge-height, auto);
            min-height: {{ badge_min_height }}px;
            padding: {{ badge_padding }};
            border-radius: {{ badge_radius }};
            background-color: var(--bbt-badge-bg, #16a34a);
            background-image: var(--bbt-badge-image);
            background-position: center;
            background-size: {{ badge_background_size }};
            background-repeat: {{ badge_background_repeat }};
            color: var(--bbt-badge-color, #ffffff);
            font-size: var(--bbt-font-size, {{ font_size }}px);
            font-family: {{ badge_font_family_value }};
            font-weight: {{ badge_font_weight_value }};
            line-height: 16px;
            text-transform: {{ badge_text_transform }};
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            border: {{ badge_border_value }};
            box-shadow: {{ badge_shadow_value }};
            opacity: var(--bbt-opacity, 1);
            transform: rotate(var(--bbt-rotation, 0deg));
            {%- if badge_clip_path != blank -%}
              clip-path: {{ badge_clip_path }};
            {%- endif -%}
          "
          aria-label="{{ mapping_label | escape }}"
        >
          <span
            class="bbt-badge__text"
            style="
              overflow: hidden;
              text-overflow: ellipsis;
              text-align: {{ text_align }};
              text-shadow: {{ badge_text_shadow_value }};
              {%- if template_type != 'text' or image_url != blank -%}
                position: absolute;
                left: var(--bbt-text-x, 50%);
                top: var(--bbt-text-y, 50%);
                width: 86%;
                transform: translate(-50%, -50%);
              {%- endif -%}
            "
          >
            {{ mapping_label | escape }}
          </span>
        </span>
        {%- assign rendered_count = rendered_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if rendered_count == 0 and request.design_mode -%}
      <div class="bbt-empty bbt-empty--inside">
        This product does not have a tag that matches a saved badge.
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product Badges",
  "target": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays badges for products whose tags match mappings saved in the Badges by Tag app."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "options": [
        { "value": "inline", "label": "Inline" },
        { "value": "top-left", "label": "Top left overlay" },
        { "value": "top-right", "label": "Top right overlay" }
      ],
      "default": "inline"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "wrap", "label": "Wrap" },
        { "value": "row", "label": "Single row" },
        { "value": "column", "label": "Column" },
        { "value": "compact", "label": "Compact" }
      ],
      "default": "wrap"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "paragraph",
      "content": "Alignment applies when Position is set to Inline. Overlay positions use the selected corner and overlay spacing."
    },
    {
      "type": "range",
      "id": "max_badges",
      "label": "Maximum badges",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_first_only",
      "label": "Show only the first matching badge",
      "default": false
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "overlay_offset",
      "label": "Overlay spacing",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    }
  ]
}
{% endschema %}
